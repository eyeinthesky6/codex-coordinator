{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${PLUGIN_ROOT}/scripts/codex_coordinator_bootstrap.sh\" \"${PLUGIN_ROOT}/scripts/codex_coordinator_session_start.py\"",
            "commandWindows": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"${PLUGIN_ROOT}/scripts/codex_coordinator_bootstrap.ps1\" -HookPath \"${PLUGIN_ROOT}/scripts/codex_coordinator_session_start.py\"",
            "timeout": 180,
            "statusMessage": "Finding Python and loading Codex Coordinator"
          }
        ]
      }
    ]
  }
}
